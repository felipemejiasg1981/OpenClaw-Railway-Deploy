{
  "$schema": "https://railway.app/v1.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/",
    "mounts": [
      {
        "mountPath": "/data",
        "repository": "openclaw-data"
      }
    ]
  }
}
